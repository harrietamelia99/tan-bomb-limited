# Which Stripe mode to use: test | live
# Defaults to live
STRIPE_MODE=live

# Test secret key (sk_test_...)
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY_TEST=

# Live secret key (sk_live_...)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY_LIVE=

# Optional fallback / legacy name for live key
# STRIPE_SECRET_KEY=

# Optional override for absolute site URL
# SITE_URL=https://tan-bomb-limited.vercel.app

# Resend contact form + order confirmations
# https://resend.com/api-keys
RESEND_API_KEY=

# Optional — defaults to Tan Bomb <info@tan-bomb.com>
# Requires tan-bomb.com verified in Resend → Domains
# RESEND_FROM=Tan Bomb <info@tan-bomb.com>

# Optional — where enquiries / order notifications are delivered
# CONTACT_TO_EMAIL=info@tan-bomb.com
# ORDER_NOTIFY_EMAIL=info@tan-bomb.com

# Stripe webhook signing secret (Whsec_...)
# Dashboard → Developers → Webhooks → endpoint for /api/stripe-webhook
# Event: checkout.session.completed
# STRIPE_WEBHOOK_SECRET=
