{%- comment -%}
  Renders a benefit card icon.
  Usage: {% render 'benefit-icon', icon: block.settings.icon %}
{%- endcomment -%}

{%- case icon -%}
  {%- when 'formula' -%}
    {%- comment -%} Tan accelerator: sun with rays {%- endcomment -%}
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="24" cy="24" r="7" stroke="currentColor" stroke-width="1.5"/>
      <path d="M24 8v4M24 36v4M8 24h4M36 24h4M13.8 13.8l2.8 2.8M31.4 31.4l2.8 2.8M13.8 34.2l2.8-2.8M31.4 16.6l2.8-2.8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>

  {%- when 'hydrate' -%}
    {%- comment -%} Hydration: water droplet {%- endcomment -%}
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M24 8c-2 8-12 14-12 24a12 12 0 1024 0C36 22 26 16 24 8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M20 30c1.5 2 3.5 3 6 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    </svg>

  {%- when 'tyrosine' -%}
    {%- comment -%} L-Tyrosine: molecule structure {%- endcomment -%}
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="24" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="14" cy="28" r="3" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="34" cy="28" r="3" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="24" cy="36" r="3" stroke="currentColor" stroke-width="1.5"/>
      <path d="M24 17v5M16.5 26.2l5-4.4M31.5 26.2l-5-4.4M24 31v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>

  {%- when 'salon' -%}
    {%- comment -%} Salon owners: shop storefront {%- endcomment -%}
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M8 20l4-8h24l4 8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M10 20h28v16a2 2 0 01-2 2H12a2 2 0 01-2-2V20z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M8 20c0 2 2 4 4 4s4-2 4-4M20 20c0 2 2 4 4 4s4-2 4-4M32 20c0 2 2 4 4 4s4-2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <rect x="20" y="28" width="8" height="10" rx="1" stroke="currentColor" stroke-width="1.5"/>
    </svg>

  {%- when 'luxury' -%}
    {%- comment -%} Gift / premium packaging {%- endcomment -%}
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M14 22h20v18a2 2 0 01-2 2H16a2 2 0 01-2-2V22z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <rect x="12" y="18" width="24" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
      <path d="M24 18v22" stroke="currentColor" stroke-width="1.5"/>
      <path d="M24 18c-3.5-4-9-3.5-9 0s3.5 4.5 9 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M24 18c3.5-4 9-3.5 9 0s-3.5 4.5-9 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- else -%}
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="24" cy="24" r="14" stroke="currentColor" stroke-width="1.5"/>
    </svg>
{%- endcase -%}
