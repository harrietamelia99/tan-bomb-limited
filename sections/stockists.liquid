<section id="stockists" class="section section--stockists fade-in">
  <div class="container section--stockists__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="section--stockists__subheading lead">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="section--stockists__actions">
      <a href="#contact" class="btn btn--primary" data-scroll-link>
        {{ section.settings.cta_label | default: 'Enquire about wholesale' }}
      </a>
    </div>

    {%- if section.settings.secondary_line != blank -%}
      <p class="section--stockists__secondary">{{ section.settings.secondary_line }}</p>
    {%- endif -%}

    <div
      class="stockist-locator"
      data-stockist-locator
      data-default-radius="{{ section.settings.default_radius | default: 25 }}"
    >
      <form class="stockist-locator__search" data-stockist-search novalidate>
        <div class="stockist-locator__search-field">
          <label class="visually-hidden" for="StockistSearch-{{ section.id }}">Postcode or town</label>
          <input
            type="search"
            id="StockistSearch-{{ section.id }}"
            class="stockist-locator__input"
            name="q"
            placeholder="{{ section.settings.search_placeholder | default: 'Enter postcode or town' }}"
            autocomplete="postal-code"
            data-stockist-query
          >
        </div>
        <div class="stockist-locator__search-field stockist-locator__search-field--radius">
          <label class="visually-hidden" for="StockistRadius-{{ section.id }}">Search radius</label>
          <select id="StockistRadius-{{ section.id }}" class="stockist-locator__select" data-stockist-radius>
            <option value="10"{% if section.settings.default_radius == 10 %} selected{% endif %}>10 miles</option>
            <option value="25"{% if section.settings.default_radius == 25 or section.settings.default_radius == blank %} selected{% endif %}>25 miles</option>
            <option value="50"{% if section.settings.default_radius == 50 %} selected{% endif %}>50 miles</option>
            <option value="100"{% if section.settings.default_radius == 100 %} selected{% endif %}>100 miles</option>
          </select>
        </div>
        <button type="submit" class="btn btn--primary stockist-locator__submit">Find stockists</button>
      </form>

      <p class="stockist-locator__status" data-stockist-status aria-live="polite">
        {%- if section.blocks.size > 0 -%}
          Showing {{ section.blocks.size }} stockist{% if section.blocks.size != 1 %}s{% endif %} near you
        {%- else -%}
          No stockists added yet
        {%- endif -%}
      </p>

      <div class="stockist-locator__layout">
        <div class="stockist-locator__results" data-stockist-results>
          {%- if section.blocks.size > 0 -%}
            <ul class="stockist-locator__list" role="list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'stockist' -%}
                  <li
                    class="stockist-locator__item{% if forloop.first %} is-active{% endif %}"
                    data-stockist-item
                    data-stockist-id="{{ block.id }}"
                    data-lat="{{ block.settings.latitude }}"
                    data-lng="{{ block.settings.longitude }}"
                    {{ block.shopify_attributes }}
                  >
                    <button type="button" class="stockist-locator__item-btn" data-stockist-select>
                      <span class="stockist-locator__item-head">
                        <span class="stockist-locator__name">{{ block.settings.name }}</span>
                        <span class="stockist-locator__distance" data-stockist-distance>—</span>
                      </span>
                      <span class="stockist-locator__address">
                        {%- if block.settings.address != blank -%}
                          {{ block.settings.address }}<br>
                        {%- endif -%}
                        {{ block.settings.city }}{% if block.settings.postcode != blank %}, {{ block.settings.postcode }}{% endif %}
                      </span>
                      {%- if block.settings.products != blank -%}
                        <span class="stockist-locator__badge">{{ block.settings.products }}</span>
                      {%- endif -%}
                    </button>
                    <div class="stockist-locator__item-actions">
                      {%- if block.settings.phone != blank -%}
                        <a href="tel:{{ block.settings.phone | replace: ' ', '' }}" class="stockist-locator__link">
                          {{ block.settings.phone }}
                        </a>
                      {%- endif -%}
                      {%- if block.settings.maps_url != blank -%}
                        <a
                          href="{{ block.settings.maps_url }}"
                          class="stockist-locator__link stockist-locator__link--directions"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          Get directions
                        </a>
                      {%- endif -%}
                    </div>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- else -%}
            <div class="stockist-locator__empty">
              <p>Add stockist blocks in the theme editor to populate the locator.</p>
            </div>
          {%- endif -%}

          <p class="stockist-locator__empty stockist-locator__empty--search" data-stockist-empty hidden>
            No stockists found within that radius. Try widening your search or <a href="#contact" data-scroll-link>get in touch</a> and we'll help.
          </p>
        </div>

        <div class="stockist-locator__map-panel" aria-hidden="false">
          <div class="stockist-locator__map" data-stockist-map>
            <div class="stockist-locator__map-canvas">
              {% render 'uk-map-svg' %}
              <div class="stockist-locator__pins" data-stockist-pins>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'stockist' -%}
                    <button
                      type="button"
                      class="stockist-locator__pin{% if forloop.first %} is-active{% endif %}"
                      data-stockist-pin
                      data-stockist-id="{{ block.id }}"
                      data-lat="{{ block.settings.latitude }}"
                      data-lng="{{ block.settings.longitude }}"
                      aria-label="{{ block.settings.name }}"
                      style="--pin-x: 50%; --pin-y: 50%;"
                    >
                      <span class="stockist-locator__pin-dot" aria-hidden="true"></span>
                    </button>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <div class="stockist-locator__map-user" data-stockist-user-pin hidden aria-hidden="true">
                <span class="stockist-locator__user-dot"></span>
              </div>
            </div>
            <p class="stockist-locator__map-caption">Map preview — locations shown for demonstration</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

