<section
  id="brand-story"
  class="section section--brand-story fade-in texture-marble{% if section.settings.image_position == 'left' %} section--brand-story--image-left{% endif %}"
>
  <div class="container section--brand-story__inner">
    <div class="section--brand-story__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.pull_quote != blank -%}
        <blockquote class="section--brand-story__pull-quote">
          <p><em>{{ section.settings.pull_quote }}</em></p>
        </blockquote>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="section--brand-story__body rte">
          {{ section.settings.body }}
        </div>
      {%- endif -%}
    </div>

    <div class="section--brand-story__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="
            {{ section.settings.image | image_url: width: 400 }} 400w,
            {{ section.settings.image | image_url: width: 600 }} 600w,
            {{ section.settings.image | image_url: width: 800 }} 800w
          "
          sizes="(max-width: 767px) 90vw, 40vw"
          alt="{{ section.settings.image.alt | default: 'Hand holding Cherry Whip tanning accelerator sachet in a salon' }}"
          width="800"
          height="1000"
          loading="lazy"
          class="section--brand-story__image"
        >
      {%- else -%}
        <img
          src="{{ 'brand-story.png' | asset_url }}"
          alt="Hand holding Cherry Whip tanning accelerator sachet in a salon"
          width="768"
          height="1024"
          loading="lazy"
          class="section--brand-story__image section--brand-story__image--default"
        >
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "tag": "section",
  "class": "section-brand-story",
  "settings": [
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "Inspired by years in the <em>tanning industry</em>"
    },
    {
      "type": "text",
      "id": "pull_quote",
      "label": "Pull quote",
      "default": "For your skin. For your shelf."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>We created Tan Bomb because we believed the tanning industry deserved more.</p><p>More than another bottle on the shelf, more than another accelerator, we wanted to create a product that looked exceptional, felt indulgent, and delivered the premium experience our clients expected.</p><p>As tanning business owners ourselves, we've spent years helping thousands of customers achieve their perfect tan. That experience inspired us to create a product that reflects the quality, luxury, and performance we believe every tanning accelerator should offer. So we created it!</p><p>Tan Bomb is a luxury tanning accelerator designed for those who expect more, from their skincare and from their tan. Beautifully formulated, elegantly packaged, and proudly made in the UK, it's a product we're proud to use ourselves, display in our salons, and recommend with complete confidence.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    }
  ],
  "presets": [
    {
      "name": "Brand story"
    }
  ]
}
{% endschema %}
