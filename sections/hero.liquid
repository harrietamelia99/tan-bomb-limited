<section
  id="hero"
  class="section section--hero section--hero--immersive section--hero--light section--hero--has-desktop-image section--hero--has-mobile-image fade-in texture-marble"
  style="--section-bg: {{ section.settings.bg_color | default: '#f5f2ee' }};"
>
  <link
    rel="preload"
    as="image"
    imagesrcset="
      {%- if section.settings.desktop_image != blank -%}
        {{ section.settings.desktop_image | image_url: width: 1920 }} 1920w,
        {{ section.settings.desktop_image | image_url: width: 2560 }} 2560w,
        {{ section.settings.desktop_image | image_url: width: 3840 }} 3840w,
        {{ section.settings.desktop_image | image_url: width: 5504 }} 5504w
      {%- else -%}
        {{ 'hero-desktop.jpg' | asset_url }} 1920w,
        {{ 'hero-desktop-2560.jpg' | asset_url }} 2560w,
        {{ 'hero-desktop-3840.jpg' | asset_url }} 3840w,
        {{ 'hero-desktop-5504.jpg' | asset_url }} 5504w
      {%- endif -%}
    "
    imagesizes="100vw"
    href="{% if section.settings.desktop_image != blank %}{{ section.settings.desktop_image | image_url: width: 3840 }}{% else %}{{ 'hero-desktop-3840.jpg' | asset_url }}{% endif %}"
    media="(min-width: 1024px)"
  >
  <link
    rel="preload"
    as="image"
    imagesrcset="
      {%- if section.settings.mobile_image != blank -%}
        {{ section.settings.mobile_image | image_url: width: 1080 }} 1080w,
        {{ section.settings.mobile_image | image_url: width: 1536 }} 1536w,
        {{ section.settings.mobile_image | image_url: width: 2048 }} 2048w,
        {{ section.settings.mobile_image | image_url: width: 3072 }} 3072w
      {%- else -%}
        {{ 'hero-mobile.jpg' | asset_url }} 1080w,
        {{ 'hero-mobile-1536.jpg' | asset_url }} 1536w,
        {{ 'hero-mobile-2048.jpg' | asset_url }} 2048w,
        {{ 'hero-mobile-3072.jpg' | asset_url }} 3072w
      {%- endif -%}
    "
    imagesizes="100vw"
    href="{% if section.settings.mobile_image != blank %}{{ section.settings.mobile_image | image_url: width: 1536 }}{% else %}{{ 'hero-mobile-1536.jpg' | asset_url }}{% endif %}"
    media="(max-width: 1023px)"
  >

  <div class="section--hero__media section--hero__media--mobile" aria-hidden="true">
    {%- if section.settings.mobile_image != blank -%}
      <img
        src="{{ section.settings.mobile_image | image_url: width: 1536 }}"
        srcset="
          {{ section.settings.mobile_image | image_url: width: 1080 }} 1080w,
          {{ section.settings.mobile_image | image_url: width: 1536 }} 1536w,
          {{ section.settings.mobile_image | image_url: width: 2048 }} 2048w,
          {{ section.settings.mobile_image | image_url: width: 3072 }} 3072w
        "
        sizes="100vw"
        alt="{{ section.settings.mobile_image.alt | default: section.settings.product_name | strip_html | default: 'Cherry Whip on a tropical beach at sunset' }}"
        width="1536"
        height="2752"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="section--hero__image section--hero__image--mobile"
      >
    {%- else -%}
      <img
        src="{{ 'hero-mobile-1536.jpg' | asset_url }}"
        srcset="
          {{ 'hero-mobile.jpg' | asset_url }} 1080w,
          {{ 'hero-mobile-1536.jpg' | asset_url }} 1536w,
          {{ 'hero-mobile-2048.jpg' | asset_url }} 2048w,
          {{ 'hero-mobile-3072.jpg' | asset_url }} 3072w
        "
        sizes="100vw"
        alt="Cherry Whip tanning accelerator on a tropical beach at sunset"
        width="1536"
        height="2752"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="section--hero__image section--hero__image--mobile"
      >
    {%- endif -%}
    <div class="section--hero__scrim section--hero__scrim--mobile"></div>
  </div>

  <div class="section--hero__media section--hero__media--desktop" aria-hidden="true">
    {%- if section.settings.desktop_image != blank -%}
      <img
        src="{{ section.settings.desktop_image | image_url: width: 3840 }}"
        srcset="
          {{ section.settings.desktop_image | image_url: width: 1920 }} 1920w,
          {{ section.settings.desktop_image | image_url: width: 2560 }} 2560w,
          {{ section.settings.desktop_image | image_url: width: 3840 }} 3840w,
          {{ section.settings.desktop_image | image_url: width: 5504 }} 5504w
        "
        sizes="100vw"
        alt="{{ section.settings.desktop_image.alt | default: section.settings.product_name | strip_html | default: 'Cherry Whip on a tropical beach at sunset' }}"
        width="3840"
        height="2143"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="section--hero__image section--hero__image--desktop"
      >
    {%- else -%}
      <img
        src="{{ 'hero-desktop-3840.jpg' | asset_url }}"
        srcset="
          {{ 'hero-desktop.jpg' | asset_url }} 1920w,
          {{ 'hero-desktop-2560.jpg' | asset_url }} 2560w,
          {{ 'hero-desktop-3840.jpg' | asset_url }} 3840w,
          {{ 'hero-desktop-5504.jpg' | asset_url }} 5504w
        "
        sizes="100vw"
        alt="Cherry Whip tanning accelerator on a tropical beach at sunset"
        width="3840"
        height="2143"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="section--hero__image section--hero__image--desktop"
      >
    {%- endif -%}
    <div class="section--hero__scrim section--hero__scrim--desktop"></div>
  </div>

  <div class="container section--hero__content section--hero__content--overlay">
    {%- if section.settings.eyebrow != blank -%}
      <p class="section--hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.product_name != blank or section.settings.heading != blank -%}
      <h1 class="section--hero__heading">
        {%- if section.settings.product_name != blank -%}
          <span class="section--hero__product-name">{{ section.settings.product_name }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <span class="section--hero__tagline">{{ section.settings.heading }}</span>
        {%- endif -%}
      </h1>
    {%- endif -%}

    <hr class="gold-divider section--hero__divider" aria-hidden="true">

    {%- if section.settings.subheading != blank -%}
      <p class="section--hero__subheading lead">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="section--hero__actions">
      {%- assign cta_href = section.settings.cta_url | default: '#shop' -%}
      <a
        href="{{ cta_href }}"
        class="btn btn--primary"
        {% if cta_href contains '#' %}data-scroll-link{% endif %}
      >
        {{ section.settings.cta_label | default: 'Shop Cherry Whip' }}
      </a>

      <a
        href="{{ section.settings.secondary_cta_url | default: '#cherry-whip' }}"
        class="btn btn--outline"
        data-scroll-link
      >
        {{ section.settings.secondary_cta_label | default: 'See more' }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Tan Bomb presents"
    },
    {
      "type": "html",
      "id": "product_name",
      "label": "Product name",
      "default": "Cherry Whip"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "<em>now</em> live <span class=\"cherry-icon\" aria-hidden=\"true\"></span>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Cherry-infused tanning accelerator built for tanners and salons alike. Shop for yourself or stock your shelf. Salon-quality formula, packaging that sells."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary CTA label",
      "default": "Shop Cherry Whip"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "Primary CTA URL",
      "default": "#shop"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "See more"
    },
    {
      "type": "text",
      "id": "secondary_cta_url",
      "label": "Secondary CTA URL",
      "default": "#cherry-whip"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop hero image (1024px and up)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile hero image (below 1024px)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#f5f2ee"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
